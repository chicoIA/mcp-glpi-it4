# ── Conexão GLPI (IT4Solução) ────────────────────────────────────────────────
GLPI_BASE_URL=https://suporte.sys.it4solucao.com.br
GLPI_API_VERSION=v2.3

# ── Credenciais OAuth2 (Setup > OAuth Clients) ───────────────────────────────
GLPI_CLIENT_ID=SEU_CLIENT_ID_AQUI
GLPI_CLIENT_SECRET=SEU_CLIENT_SECRET_AQUI
GLPI_USERNAME=usuario_de_servico
GLPI_PASSWORD=SUA_SENHA_AQUI
GLPI_OAUTH_SCOPE=api

# ── Segurança de escrita ─────────────────────────────────────────────────────
# dry_run (padrão): simula POST/PATCH/DELETE e devolve o payload, sem alterar nada.
# live: executa de verdade (toda escrita continua registrada para rollback).
GLPI_WRITE_MODE=dry_run

# ── Tuning (opcional) ────────────────────────────────────────────────────────
GLPI_TIMEOUT=15
GLPI_MAX_RETRIES=3
# Pasta onde ficam rollback_log.json e error_log.json (default: dir atual)
GLPI_AUDIT_DIR=.
